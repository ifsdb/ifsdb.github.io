---
interface Props {
  id: string;
  width?: number;
  height?: number;
  label?: string;
  aifs?: string;
  block?: string;
  root?: string;
}

const { id, width = 400, height = 400, label, aifs, block, root } = Astro.props;
---
<div class="ifs-canvas-wrapper">
  <div class="ifs-canvas-frame">
    <canvas id={id} data-ifs-id={id} width={width} height={height}
            aria-label={label ?? id}
            title="Open in IFStile"
            style="cursor:pointer"
            data-aifs={aifs ?? ''}
            data-ifs-block={block ?? ''}
            data-ifs-root={root ?? ''}></canvas>
    <div class="ifs-open-hint">Open in IFStile ↗</div>
  </div>
</div>

<script>
  // ── Shared worker (module-level; Astro deduplicates this script across instances) ──

  declare const __IFSLIB_VERSION__: string;

  let _worker: Worker | null = null;
  const _pending = new Map<string, HTMLCanvasElement>();
  const _done = new Set<string>();

  function getWorker(): Worker {
    if (_worker) return _worker;
    _worker = new Worker('/ifslib-worker.js');
    _worker.onmessage = (e: MessageEvent) => {
      const { id, type, pixels, width, height, message } = e.data;
      const canvas = _pending.get(id);
      if (!canvas) return;

      if (type === 'frame') {
        const arr = new Uint8ClampedArray((pixels as Uint8ClampedArray).buffer as ArrayBuffer);
        const imgData = new ImageData(arr, width, height);
        createImageBitmap(imgData).then(bitmap => {
          const ctx = canvas.getContext('2d')!;
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          // Nearest-neighbour while upscaling, smooth at final resolution
          ctx.imageSmoothingEnabled = width < canvas.width;
          // ifslib uses Y-up coordinates; flip vertically to match canvas Y-down
          ctx.save();
          ctx.scale(1, -1);
          ctx.drawImage(bitmap, 0, -canvas.height, canvas.width, canvas.height);
          ctx.restore();
          bitmap.close();
        });
      } else if (type === 'done') {
        if (_pending.has(id)) {
          _pending.delete(id);
          _done.add(id);
        }
      } else if (type === 'error') {
        console.error('IFS worker error:', message, '— canvas:', id);
        _pending.delete(id);
        // Draw the error message directly on the canvas so it's visible without devtools.
        const ctx = canvas.getContext('2d');
        if (ctx) {
          const w = canvas.width, h = canvas.height;
          ctx.fillStyle = '#1a0008';
          ctx.fillRect(0, 0, w, h);
          ctx.fillStyle = '#ff6b6b';
          const fontSize = Math.max(11, Math.min(14, Math.floor(w / 28)));
          ctx.font = `${fontSize}px monospace`;
          ctx.textBaseline = 'top';
          const maxW = w - 16;
          // Word-wrap the message into lines
          const words = ('Error: ' + message).split(' ');
          const lines: string[] = [];
          let line = '';
          for (const word of words) {
            const test = line ? line + ' ' + word : word;
            if (ctx.measureText(test).width > maxW && line) { lines.push(line); line = word; }
            else line = test;
          }
          if (line) lines.push(line);
          const lineH = fontSize * 1.4;
          const totalH = lines.length * lineH;
          const startY = Math.max(8, (h - totalH) / 2);
          lines.forEach((l, i) => ctx.fillText(l, 8, startY + i * lineH, maxW));
        }
      }
    };
    _worker.onerror = (e) => console.error('IFS worker crashed:', e);
    return _worker;
  }

  function isInViewport(el: Element): boolean {
    const r = el.getBoundingClientRect();
    return r.bottom > 0 && r.top < window.innerHeight && r.right > 0 && r.left < window.innerWidth;
  }

  async function renderCanvas(canvas: HTMLCanvasElement): Promise<void> {
    const ifsId = canvas.dataset.ifsId;
    if (!ifsId) return;

    // Mark as in-progress before any await so cancelCanvas can see it.
    _pending.set(ifsId, canvas);

    // Scale canvas backing store to physical pixels for HiDPI screens.
    const dpr = window.devicePixelRatio || 1;
    if (dpr > 1 && !canvas.dataset.dprApplied) {
      // Read the actual CSS-rendered dimensions (respects max-width, flex, etc.)
      const rect = canvas.getBoundingClientRect();
      const cssW = rect.width  || canvas.width;
      const cssH = rect.height || canvas.height;
      canvas.style.width  = cssW + 'px';
      canvas.style.height = cssH + 'px';
      canvas.width  = Math.round(cssW * dpr);
      canvas.height = Math.round(cssH * dpr);
      canvas.dataset.dprApplied = '1';
    }

    // Prefer inline AIFS; fall back to fetching the file.
    let aifs = canvas.dataset.aifs ?? '';
    if (!aifs) {
      const resp = await fetch(`/aifs/${ifsId}.aifs`);
      if (!resp.ok) { _pending.delete(ifsId); return; }
      aifs = await resp.text();
    }

    // Check if cancelled while we were awaiting the fetch.
    if (!_pending.has(ifsId)) return;

    getWorker().postMessage({
      id: ifsId,
      aifs,
      block: canvas.dataset.ifsBlock ?? '',
      root: canvas.dataset.ifsRoot ?? '',
      width: canvas.width,
      height: canvas.height,
      version: __IFSLIB_VERSION__,
      priority: isInViewport(canvas),
    });
  }

  function cancelCanvas(canvas: HTMLCanvasElement) {
    const ifsId = canvas.dataset.ifsId;
    if (!ifsId || !_pending.has(ifsId)) return;
    _pending.delete(ifsId);
    getWorker().postMessage({ id: ifsId, type: 'cancel' });
  }

  function openInIFStile(canvas: HTMLCanvasElement) {
    const aifs = canvas.dataset.aifs;
    if (!aifs) return;
    const b64 = btoa(unescape(encodeURIComponent(aifs)));
    window.open('https://app.ifstile.com?aifs=' + b64, '_blank', 'noopener');
  }

  function initAll() {
    // Inner observer (no margin): marks canvases actually visible on screen as priority.
    const innerObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const canvas = entry.target as HTMLCanvasElement;
        const ifsId = canvas.dataset.ifsId!;
        if (_pending.has(ifsId)) {
          getWorker().postMessage({ id: ifsId, type: 'priority', priority: entry.isIntersecting });
        }
      });
    }, { rootMargin: '0px' });

    // Outer observer (200px margin): starts/cancels renders.
    const outerObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const canvas = entry.target as HTMLCanvasElement;
        const ifsId = canvas.dataset.ifsId!;
        if (entry.isIntersecting) {
          // Start render only if not already done or in progress.
          if (!_done.has(ifsId) && !_pending.has(ifsId)) {
            renderCanvas(canvas).catch(err => console.error('IFS render error:', err));
          }
        } else {
          // Canvas left viewport — cancel any in-progress render.
          cancelCanvas(canvas);
        }
      });
    }, { rootMargin: '200px' });

    document.querySelectorAll<HTMLCanvasElement>('canvas[data-ifs-id]').forEach(c => {
      outerObserver.observe(c);
      innerObserver.observe(c);
      c.addEventListener('click', () => openInIFStile(c));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
</script>
