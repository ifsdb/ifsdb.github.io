---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  name: string;
  dimension?: string;
}

const { title, description, name, dimension } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <main>
    <h1>{name}</h1>
    {dimension && (
      <div class="meta-block">
        <span>Fractal dimension:</span>
        <strong>{dimension}</strong>
      </div>
    )}
    <slot />
  </main>
</BaseLayout>
