---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  name: string;
  dimension?: string;
  boundaryDimension?: string;
  slug?: string;
}

const { title, description, name, dimension, boundaryDimension, slug } = Astro.props;
const githubUrl = slug
  ? `https://github.com/ifsdb/ifsdb.github.io/blob/main/src/content/ifs/${slug}.md`
  : null;
---
<BaseLayout title={title} description={description}>
  <main>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/ifs">← Catalog</a>
    </nav>
    <h1>{name}</h1>
    {dimension && (
      <div class="meta-block">
        <span>Fractal dimension:</span>
        <strong>{dimension}</strong>
      </div>
    )}
    {boundaryDimension && (
      <div class="meta-block">
        <span>Boundary dimension:</span>
        <strong>{boundaryDimension}</strong>
      </div>
    )}
    <slot />
    <div class="edit-on-github">
      {githubUrl && <a href={githubUrl} target="_blank" rel="noopener">Edit this page on GitHub ↗</a>}
    </div>
  </main>
</BaseLayout>
