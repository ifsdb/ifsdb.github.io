---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IFSCanvas from '../../components/IFSCanvas.astro';

const entries = await getCollection('ifs');
const allTags = [...new Set(entries.flatMap(e => e.data.tags ?? []))].sort();
---
<BaseLayout title="IFS Catalog" description="Browse all Iterated Function Systems in the encyclopedia">
  <main>
    <h1>IFS Catalog</h1>
    <p>A curated collection of Iterated Function System attractors with mathematical definitions and visualizations.
      <span class="catalog-stats">{entries.length} entries &middot; {allTags.length} tags</span>
    </p>

    <div class="catalog-controls">
      <div class="catalog-filters">
        <span>Filter:</span>
        <button class="filter-btn" data-tag="">All</button>
        <button class="filter-btn active" data-tag="plane">2D</button>
        <button class="filter-btn" data-tag="3d">3D</button>
        {allTags.filter(t => t !== 'plane' && t !== '3d').map(tag => (
          <button class="filter-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
      <div class="catalog-sort">
        <label for="sort-select">Sort by:</label>
        <select id="sort-select">
          <option value="name">Name</option>
          <option value="dimension">Dimension</option>
          <option value="boundary">Boundary dim</option>
          <option value="transforms">Transforms</option>
        </select>
      </div>
    </div>

    <div class="catalog-grid" id="catalog-grid">
      {entries.map(entry => (
        <div class="entry-card"
             data-tags={(entry.data.tags ?? []).join(',')}
             data-name={entry.data.name}
             data-dimension={entry.data.dimension ?? ''}
             data-boundary={entry.data.boundaryDimension ?? ''}
             data-transforms={entry.data.transforms}>
          <h3><a href={`/ifs/${entry.id}`}>{entry.data.name}</a></h3>
          <p>{entry.data.cardDescription ?? entry.data.description}</p>
          <IFSCanvas
            id={`catalog-${entry.id}`}
            width={300}
            height={300}
            label={entry.data.name}
            aifs={entry.data.aifs}
          />
          <div class="entry-card-meta">
            {(entry.data.tags ?? []).map(tag => <span class="tag">{tag}</span>)}
          </div>
          <a href={`/ifs/${entry.id}`}>View full entry →</a>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<script>
  const grid = document.getElementById('catalog-grid')!;
  const cards = () => Array.from(grid.querySelectorAll<HTMLElement>('.entry-card'));

  // ── Filtering: multi-select toggle, OR logic ──
  // "All" button clears all other selections.
  const activeFilters = new Set<string>(['plane']); // default: 2D

  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? '';
      const dimTags = ['plane', '3d'];

      if (tag === '') {
        // "All" — clear everything
        activeFilters.clear();
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      } else {
        // Remove "All" active state if it was on
        document.querySelector('.filter-btn[data-tag=""]')?.classList.remove('active');

        if (dimTags.includes(tag)) {
          // 2D/3D are mutually exclusive: clicking one deactivates the other dim tag
          if (activeFilters.has(tag)) {
            activeFilters.delete(tag);
            btn.classList.remove('active');
          } else {
            // Remove the other dim tag first
            dimTags.forEach(d => {
              if (d !== tag) {
                activeFilters.delete(d);
                document.querySelector(`.filter-btn[data-tag="${d}"]`)?.classList.remove('active');
              }
            });
            activeFilters.add(tag);
            btn.classList.add('active');
          }
        } else {
          // Other tags: free toggle
          if (activeFilters.has(tag)) {
            activeFilters.delete(tag);
            btn.classList.remove('active');
          } else {
            activeFilters.add(tag);
            btn.classList.add('active');
          }
        }
      }
      applyFilterSort();
    });
  });

  // ── Sorting ──
  document.getElementById('sort-select')!.addEventListener('change', applyFilterSort);

  function applyFilterSort() {
    const sortBy = (document.getElementById('sort-select') as HTMLSelectElement).value;
    const sorted = cards().sort((a, b) => {
      if (sortBy === 'name') return a.dataset.name!.localeCompare(b.dataset.name!);
      if (sortBy === 'transforms') return Number(a.dataset.transforms) - Number(b.dataset.transforms);
      if (sortBy === 'dimension') return (a.dataset.dimension ?? '').localeCompare(b.dataset.dimension ?? '');
      if (sortBy === 'boundary') {
        const parse = (s: string) => { const m = s.match(/[\d.]+/); return m ? parseFloat(m[0]) : NaN; };
        const av = parse(a.dataset.boundary ?? '');
        const bv = parse(b.dataset.boundary ?? '');
        if (isNaN(av) && isNaN(bv)) return a.dataset.name!.localeCompare(b.dataset.name!);
        if (isNaN(av)) return 1;
        if (isNaN(bv)) return -1;
        return av - bv;
      }
      return 0;
    });
    sorted.forEach(card => {
      const tags = card.dataset.tags?.split(',') ?? [];
      // Show if no filters active, or card matches ALL active filters (AND logic).
      const visible = activeFilters.size === 0 || [...activeFilters].every(t => tags.includes(t));
      card.style.display = visible ? '' : 'none';
      grid.appendChild(card);
    });
  }

  // Apply default filter (2D) on load.
  applyFilterSort();
</script>
